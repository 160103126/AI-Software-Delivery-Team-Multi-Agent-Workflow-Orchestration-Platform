# Backend Environment Variables - Example (.env.example)
# Copy to .env and fill with your values

# LLM Configuration
AI_SDLC_USE_LLM=true
AI_SDLC_LLM_PROVIDER=vertex

# GCP Configuration (required for Vertex AI)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini Configuration
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TEMPERATURE=0.2

# Logging
LOG_LEVEL=INFO

# Redis (optional - for LLM response caching)
# Format: redis://HOST:PORT
# Leave empty to disable caching
REDIS_URL=

# For local development with Google Generative AI (instead of Vertex AI)
# Uncomment and set if using Google API key fallback
# GOOGLE_API_KEY=your-api-key-here
