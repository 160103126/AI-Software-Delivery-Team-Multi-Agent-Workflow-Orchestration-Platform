# Backend Environment Variables - Example (.env.example)
# Copy to .env and fill with your values

# LLM Configuration
AI_SDLC_USE_LLM=true
AI_SDLC_LLM_PROVIDER=vertex

# GCP Configuration (required for Vertex AI)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini Configuration
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TEMPERATURE=0.2

# Logging
LOG_LEVEL=INFO

# Redis (optional - for LLM response caching + LangGraph checkpointing)
# Format: redis://HOST:PORT
# Leave empty to disable caching and use in-memory checkpointing
# Requires Redis 8.0+ or Redis Stack (RedisJSON + RediSearch modules)
REDIS_URL=

# LangSmith (optional - for tracing, debugging, and monitoring)
# Sign up at https://smith.langchain.com and create an API key.
# All LangChain/LangGraph calls are automatically traced when enabled.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=ai-sdlc
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# For local development with Google Generative AI (instead of Vertex AI)
# Uncomment and set if using Google API key fallback
# GOOGLE_API_KEY=your-api-key-here

