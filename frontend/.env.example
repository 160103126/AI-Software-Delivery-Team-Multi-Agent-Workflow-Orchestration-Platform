# Frontend Environment Variables - Example (.env.example)
# Copy to .env and fill with your values

# Backend API URL
# Local development:
API_BASE_URL=http://127.0.0.1:8000

# Docker local:
# API_BASE_URL=http://host.docker.internal:8000

# Cloud Run production:
# API_BASE_URL=https://ai-sdlc-backend-xxxxx.run.app

# Logging
LOG_LEVEL=INFO
